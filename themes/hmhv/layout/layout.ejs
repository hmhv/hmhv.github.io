<%#
  layout.ejs — top-level wrapper for every page
-%>
<!doctype html>
<html lang="<%= config.language || 'ja' %>">
<head>
<%- partial('_partial/head') %>
</head>
<body data-layout="<%= page.layout || '' %>">
  <%- partial('_partial/header') %>
  <%- body %>
  <%- partial('_partial/footer') %>
  <script src="<%- url_for('/js/theme.js') %>" defer></script>
</body>
</html>
