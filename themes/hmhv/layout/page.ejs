<%#
  page.ejs — generic static page (about, etc.)
-%>
<main class="site">
  <div class="reader">
    <div class="post-hd">
      <div class="eyebrow"><%= page.eyebrow || (page.title || '').toUpperCase() %></div>
      <h1><%= page.title %></h1>
    </div>
    <article class="prose">
      <%- page.content %>
    </article>
  </div>
</main>
