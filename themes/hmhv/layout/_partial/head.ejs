<%#
  head.ejs — <head> contents
-%>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="<%= page.description || config.description || theme.site.hero_sub %>">
<meta name="author" content="<%= config.author || theme.site.brand %>">

<% if (is_post()) { %>
<meta property="og:type" content="article">
<meta property="article:published_time" content="<%= date_xml(page.date) %>">
<% } else { %>
<meta property="og:type" content="website">
<% } %>
<meta property="og:title" content="<%= page.title || config.title %>">
<meta property="og:description" content="<%= page.description || config.description || theme.site.hero_sub %>">
<meta property="og:site_name" content="<%= config.title %>">

<title>
<% if (page.title && !is_home()) { %><%= page.title %> — <%= config.title %><% } else { %><%= config.title %><% if (config.subtitle) { %> — <%= config.subtitle %><% } %><% } %>
</title>

<% if (theme.favicon) { %>
<link rel="icon" href="<%- url_for(theme.favicon) %>">
<% } %>

<% if (theme.fonts && theme.fonts.enable) { %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?<%- theme.fonts.families.map(f => 'family=' + f).join('&') %>&display=swap">
<% } %>

<script>
(function(){try{var s=localStorage.getItem('hmhv-theme');var m=s||(matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light');document.documentElement.setAttribute('data-theme',m);}catch(e){}})();
</script>

<link rel="stylesheet" href="<%- url_for('/css/style.css') %>">
<% if (config.feed && config.feed.path) { %>
<link rel="alternate" type="application/atom+xml" title="<%= config.title %>" href="<%- url_for(config.feed.path) %>">
<% } %>
