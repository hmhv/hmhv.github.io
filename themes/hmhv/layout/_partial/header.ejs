<%#
  header.ejs — sticky top bar
-%>
<header class="hdr">
  <div class="site hdr-inner">
    <a class="hdr-logo" href="<%- url_for('/') %>">
      <% if (theme.logo) { %><img src="<%- url_for(theme.logo) %>" alt="<%= theme.site.brand %>"><% } %>
      <span class="wm"><%= theme.site.brand %></span>
    </a>
    <nav class="hdr-nav">
      <% for (const label in theme.menu) { %>
        <%
          const href = theme.menu[label];
          const cur  = page.path ? ('/' + page.path) : '';
          let on = false;
          if (href === '/' && (is_home() || cur === '/')) on = true;
          else if (href !== '/' && cur.indexOf(href.replace(/\/$/, '')) === 0) on = true;
        %>
        <a class="<%= on ? 'on' : '' %>" href="<%- url_for(href) %>"><%= label %></a>
      <% } %>
      <button type="button" id="theme-toggle" class="theme-toggle theme-toggle-nav" aria-label="Toggle theme">
        <svg class="ic-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
      </button>
    </nav>
  </div>
</header>
