<%#
  tags.ejs — /tags/ index: full tag cloud
-%>
<main class="site">
  <div class="archive-hd">
    <div class="eyebrow-xs"><%= __('tag.eyebrow') %></div>
    <h1 class="archive-title"><%= page.title || 'tags' %></h1>
    <p class="archive-sub"><%= site.tags.length %> tags</p>
  </div>

  <div class="tagcloud">
    <% site.tags.sort('-length').each(function(t) {
       const v = (theme.tag_chip && theme.tag_chip[t.name]) || 'default';
       const cls = v === 'default' ? 'chip' : 'chip ' + v;
    %>
      <a class="<%= cls %>" href="<%- url_for(t.path) %>">#<%= t.name %><span class="chip-count"><%= t.length %></span></a>
    <% }) %>
  </div>
</main>
